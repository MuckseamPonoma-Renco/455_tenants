ENV=dev
INGEST_TOKEN=change_me_long_random
MOBILE_FILER_TOKEN=
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/tenant_issue_os
REDIS_URL=redis://redis:6379/0
# Safe first-run defaults for local/dev and the initial Render deploy.
PROCESS_INLINE=1
DISABLE_SHEETS_SYNC=1

GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp_sa.json
GOOGLE_SHEETS_SPREADSHEET_ID=replace_me
SHEETS_INCIDENTS_TAB=Incidents
SHEETS_DASHBOARD_TAB=Dashboard
SHEETS_COVERAGE_TAB=Coverage
SHEETS_311_CASES_TAB=Cases311
SHEETS_311_QUEUE_TAB=Queue311

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ESCALATE_MODEL=gpt-5-mini
LLM_MODE=off
LLM_MIN_CONFIDENCE=65
LLM_MAX_OUTPUT_TOKENS=220

ELEVATOR_SILENCE_GAP_SECONDS=7200
OTHER_WINDOW_SECONDS=21600

BUILDING_NAME=455 Ocean Parkway
BUILDING_STREET_ADDRESS=455 Ocean Pkwy
BUILDING_CITY=Brooklyn
BUILDING_STATE=NY
BUILDING_ZIP=11218
BUILDING_BOROUGH=Brooklyn
BUILDING_NOTES=18-story rental building with chronic elevator outages.
AUTO_FILE_ENABLED=1
AUTO_FILE_MIN_WITNESSES=1
AUTO_FILE_MIN_REPORTS=1
AUTO_FILE_ELEVATOR_ONLY=1
NYC311_CONTACT_NAME=Replace Me
NYC311_CONTACT_PHONE=5555555555
NYC311_CONTACT_EMAIL=replace@example.com
NYC311_TRACKER_ENDPOINT=https://data.cityofnewyork.us/resource/erm2-nwe9.json
